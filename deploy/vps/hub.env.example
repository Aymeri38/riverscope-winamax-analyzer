# Suivi adverse post-session : activer seulement après avoir généré deux clés
# base64 indépendantes de 32 octets dans le fichier privé hub.env.
WXA_HUB_OPPONENT_TRACKING=NO
WXA_HUB_OPPONENT_IDENTITY_KEY=''
WXA_HUB_OPPONENT_ENCRYPTION_KEY=''
