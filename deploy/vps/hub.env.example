# Ce modèle est copié vers ~/riverscope-hub/secrets/hub.env (0600).
# Ne jamais enregistrer le fichier réel dans Git.
WXA_COMMUNITY_APPROVAL_ACK=NO
WXA_COMMUNITY_APPROVAL_REFERENCE='REPLACE_WITH_WRITTEN_APPROVAL_REFERENCE'

WXA_HUB_HOST=0.0.0.0
WXA_HUB_PORT=8040
WXA_HUB_TRUSTED_HOSTS='vps-6291e853.vps.ovh.net,51.91.102.160'
