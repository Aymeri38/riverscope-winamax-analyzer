# Exemple uniquement : les scripts PowerShell ne chargent pas ce fichier automatiquement.
# Copiez les valeurs utiles dans la session PowerShell avec $env:NOM="valeur".

# Verrou explicite : requis pour toute administration ou exécution du hub.
WXA_COMMUNITY_APPROVAL_ACK=NO
WXA_COMMUNITY_APPROVAL_REFERENCE=

# Par défaut, le hub reste strictement local au PC hôte.
WXA_HUB_HOST=127.0.0.1
WXA_HUB_PORT=8040
WXA_HUB_DATA_DIR=hub-data
WXA_HUB_TRUSTED_HOSTS=127.0.0.1,localhost
WXA_HUB_ENABLE_DOCS=NO

# Limites applicatives par minute. Le hub utilise uniquement l'IP du pair TCP
# et ignore volontairement X-Forwarded-For. Un reverse proxy externe doit donc
# appliquer ses propres limites et protections en bordure.
WXA_HUB_RATE_LIMIT_ENROLL_PER_MINUTE=10
WXA_HUB_RATE_LIMIT_SYNC_PER_MINUTE=20
WXA_HUB_RATE_LIMIT_OTHER_PER_MINUTE=240
WXA_HUB_RATE_LIMIT_MAX_BUCKETS=10000
WXA_HUB_MAX_TOURNAMENTS_PER_MEMBER=50000
WXA_HUB_MAX_HANDS_PER_MEMBER=1000000
WXA_HUB_MAX_PAYLOAD_BYTES_PER_MEMBER=2147483648
WXA_HUB_MAX_RECEIPTS_PER_TOURNAMENT=16

# Suivi persistant des adversaires post-session. Les deux clés doivent être
# deux valeurs base64 indépendantes de 32 octets et ne doivent jamais entrer
# dans Git ni dans SQLite. Utiliser un générateur cryptographique (`openssl
# rand -base64 32` sous Linux) et générer une valeur différente pour chaque clé.
WXA_HUB_OPPONENT_TRACKING=NO
WXA_HUB_OPPONENT_IDENTITY_KEY=
WXA_HUB_OPPONENT_ENCRYPTION_KEY=
WXA_HUB_OPPONENT_KEY_VERSION=1
WXA_HUB_OPPONENT_RETENTION_DAYS=365

# Obligatoires dès que WXA_HUB_HOST n'est pas une adresse loopback.
WXA_HUB_TLS_CERT=
WXA_HUB_TLS_KEY=

# Facultatif sur les PC clients : certificat PEM de l'autorité publique/privée
# qui a signé le certificat TLS du hub. Ne jamais indiquer une clé privée ici.
# Aucun mode de désactivation de la vérification TLS n'est disponible.
WXA_COMMUNITY_CA_CERT=
